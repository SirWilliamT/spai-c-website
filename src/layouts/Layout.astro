---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Official website of SpAi-C - Digital AI Music Artist" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | SpAi-C</title>
		<meta name="description" content={description} />
	</head>
	<body class="bg-space-black text-white selection:bg-accent selection:text-white">
		<header class="fixed top-0 left-0 w-full z-50 bg-space-black/80 backdrop-blur-md border-b border-white/10">
			<nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
				<a href="/" class="text-2xl font-audiowide text-white hover:text-accent transition-colors">
					SpAi-C
				</a>
				
				<ul class="hidden md:flex space-x-8 font-oxanium text-sm uppercase tracking-widest">
					<li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
					<li><a href="/news" class="hover:text-accent transition-colors">Latest Transmission</a></li>
					<li><a href="/discography" class="hover:text-accent transition-colors">Discography</a></li>
					<li><a href="/about" class="hover:text-accent transition-colors">About</a></li>
					<li><a href="/contact" class="hover:text-accent transition-colors">Contact</a></li>
				</ul>

				<!-- Mobile Menu Button (Simplified for now) -->
				<div class="md:hidden text-accent">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
					</svg>
				</div>
			</nav>
		</header>

		<main class="pt-20">
			<slot />
		</main>

		<footer class="py-12 border-t border-white/10 mt-20 bg-space-deep">
			<div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8">
				<div class="text-center md:text-left">
					<p class="font-audiowide text-xl mb-2">SpAi-C</p>
					<p class="text-white/50 text-sm font-oxanium tracking-wider">Digital AI Music Artist</p>
				</div>
				
				<div class="flex space-x-6">
					<a href="#" class="text-white/60 hover:text-white transition-colors">TikTok</a>
					<a href="#" class="text-white/60 hover:text-white transition-colors">Threads</a>
					<a href="#" class="text-white/60 hover:text-white transition-colors">YouTube</a>
					<a href="#" class="text-white/60 hover:text-white transition-colors">X</a>
					<a href="#" class="text-white/60 hover:text-white transition-colors">Instagram</a>
				</div>
				
				<div class="text-white/30 text-xs font-oxanium uppercase tracking-widest">
					&copy; {new Date().getFullYear()} SpAi-C. All rights reserved.
				</div>
			</div>
		</footer>
	</body>
</html>
