---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { albums } from '../../data/albums';
---

<Layout title="Discography">
	<section class="max-w-7xl mx-auto px-6 py-20">
		<header class="mb-16">
			<span class="text-accent font-oxanium tracking-[0.3em] uppercase text-sm mb-2 block">Archive</span>
			<h1 class="text-5xl md:text-6xl font-oxanium">Discography</h1>
		</header>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
			{albums.map((album) => (
				<a href={`${import.meta.env.BASE_URL}/discography/${album.id}`} class="group">
					<div class="relative aspect-square overflow-hidden rounded-lg mb-4 bg-white/5 border border-white/10">
						<Image 
							src={album.art} 
							alt={album.title} 
							class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-110"
						/>
						<div class="absolute inset-0 bg-accent/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
							<span class="bg-white text-space-black font-oxanium font-bold px-6 py-2 rounded-full text-xs uppercase tracking-widest">View Details</span>
						</div>
					</div>
					<h3 class="text-xl font-oxanium group-hover:text-accent transition-colors">{album.title}</h3>
					<div class="flex items-center space-x-2 text-white/40 font-oxanium text-xs uppercase tracking-widest mt-1">
						<span>{album.year}</span>
						<span>•</span>
						<span>{album.type}</span>
					</div>
				</a>
			))}
		</div>
	</section>
</Layout>
