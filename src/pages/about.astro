				</div>
			</div>
		</div>
		<!--
		<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
			<div class="aspect-square bg-white/5 border border-white/10 rounded-lg"></div>
			<div class="aspect-square bg-white/5 border border-white/10 rounded-lg"></div>
			<div class="aspect-square bg-white/5 border border-white/10 rounded-lg"></div>
			<div class="aspect-square bg-white/5 border border-white/10 rounded-lg"></div>
		</div>
		-->
	</section>
</Layout>