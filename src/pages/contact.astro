---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
	<section class="max-w-6xl mx-auto px-6 py-20">
		<header class="mb-16 text-center">
			<span class="text-accent font-oxanium tracking-[0.3em] uppercase text-sm mb-2 block">Connect</span>
			<h1 class="text-5xl md:text-6xl font-audiowide">Contact & Licensing</h1>
		</header>

		<div class="grid md:grid-cols-2 gap-16">
			<!-- Contact Info & Licensing -->
			<div class="space-y-12">
				<div class="space-y-6">
					<h2 class="text-3xl font-audiowide text-white">Licensing</h2>
					<p class="text-white/70 font-inter leading-relaxed">
						All SpAi-C musical transmissions are available for licensing in commercial projects, films, games, and digital media. Our AI-generated compositions offer unique, futuristic soundscapes for your vision.
					</p>
					<div class="bg-white/5 border border-white/10 p-6 rounded-xl">
						<h4 class="font-oxanium text-accent uppercase tracking-widest text-xs mb-2">Standard Inquiries</h4>
						<p class="font-oxanium text-lg">licensing@spai-c.com</p>
					</div>
				</div>

				<div class="space-y-6">
					<h2 class="text-3xl font-audiowide text-white">Press Kit</h2>
					<p class="text-white/70 font-inter leading-relaxed">
						Download the official SpAi-C press kit containing high-resolution assets, biographies, and promotional materials.
					</p>
					<a href="#" class="inline-flex items-center text-sm font-oxanium uppercase tracking-widest text-white hover:text-accent transition-colors">
						Download Press Kit (.ZIP)
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
						</svg>
					</a>
				</div>
			</div>

			<!-- Contact Form -->
			<div class="bg-white/5 border border-white/10 p-8 md:p-10 rounded-2xl">
				<h2 class="text-3xl font-audiowide mb-8">Send a Message</h2>
				<form action="https://formspree.io/f/your-id" method="POST" class="space-y-6 font-oxanium">
					<div class="space-y-2">
						<label for="name" class="text-xs uppercase tracking-widest text-white/50">Name</label>
						<input 
							type="text" 
							id="name" 
							name="name" 
							required 
							class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 focus:outline-none focus:border-accent transition-colors"
							placeholder="Your Name"
						/>
					</div>
					<div class="space-y-2">
						<label for="email" class="text-xs uppercase tracking-widest text-white/50">Email Address</label>
						<input 
							type="email" 
							id="email" 
							name="email" 
							required 
							class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 focus:outline-none focus:border-accent transition-colors"
							placeholder="email@example.com"
						/>
					</div>
					<div class="space-y-2">
						<label for="subject" class="text-xs uppercase tracking-widest text-white/50">Subject</label>
						<select 
							id="subject" 
							name="subject" 
							class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 focus:outline-none focus:border-accent transition-colors appearance-none"
						>
							<option value="general">General Inquiry</option>
							<option value="licensing">Licensing Request</option>
							<option value="press">Press & Media</option>
							<option value="booking">Booking</option>
						</select>
					</div>
					<div class="space-y-2">
						<label for="message" class="text-xs uppercase tracking-widest text-white/50">Message</label>
						<textarea 
							id="message" 
							name="message" 
							required 
							rows="5" 
							class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 focus:outline-none focus:border-accent transition-colors resize-none"
							placeholder="Transmission details..."
						></textarea>
					</div>
					<button 
						type="submit" 
						class="w-full bg-white text-space-black font-bold py-4 rounded-lg hover:bg-accent hover:text-white transition-all uppercase tracking-widest text-sm"
					>
						Send Transmission
					</button>
				</form>
			</div>
		</div>
	</section>
</Layout>
