---
import Layout from '../layouts/Layout.astro';

const news = [
  {
    date: "July 31, 2026",
    title: "Transmission incoming...",
    excerpt: "SpAi-C's first single Gravi-tea arrives 31 July.",
	link: "https://distrokid.com/hyperfollow/spaic/gravi-tea",
	linkText: "🚀 Pre-save now",
    category: "Announcement",
	readmore: ""
  }
];
---

<Layout title="Latest Transmission">
	<section class="max-w-4xl mx-auto px-6 py-20">
		<header class="mb-16">
			<span class="text-accent font-oxanium tracking-[0.3em] uppercase text-sm mb-2 block text-center">Data Stream</span>
			<h1 class="text-5xl md:text-6xl font-oxanium text-center">Latest Transmission</h1>
		</header>

		<div class="space-y-12">
		<h2 class="text-2xl font-oxanium mb-4 group-hover:text-accent transition-colors">Coming 31 July...</h2>
			{news.map((item) => (
				<article class="group relative bg-white/5 border border-white/10 p-8 rounded-2xl hover:bg-white/[0.08] transition-all">
					<div class="flex flex-col md:flex-row md:items-center justify-between mb-4 gap-2">
						<span class="text-accent font-oxanium text-xs uppercase tracking-widest">{item.category}</span>
						<time class="text-white/40 font-oxanium text-xs">{item.date}</time>
					</div>
					<h2 class="text-2xl font-oxanium mb-4 group-hover:text-accent transition-colors">{item.title}</h2>
					<p class="text-white/60 font-inter leading-relaxed mb-6">
						{item.excerpt}
					</p>
					{item.link && 
					<div class="pt-4">
					<a 
						href={item.link}
						class="inline-block bg-white text-space-black font-oxanium font-bold px-8 py-4 rounded-full hover:bg-accent hover:text-white transition-all transform hover:-translate-y-1 active:scale-95 tracking-widest uppercase text-sm"
					>
						{item.linkText}
					</a>
					</div>}
					{readmore && <p>
						<a href={item.readmore} class="inline-flex items-center text-sm font-oxanium uppercase tracking-widest text-white hover:text-accent transition-colors">
							Read More 
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</a>
					</p>}
				</article>
			))}
		</div>
	</section>
</Layout>
